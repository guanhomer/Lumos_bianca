// nextflow.config

// process.executor = 'slurm'

//cleanup after successful run
cleanup = false

//default output folder, could be changed with -output-dir XXX
outputDir = 'lumos_out'

params {
    outputDir = 'lumos_out'
}

workflow {
    output {
        mode = 'link'   //use hard links for final results
    }
}

timeline {
  enabled = true
  file    = "${params.outputDir}/execution/pipeline.timeline.html"
  overwrite = true
}

report {
  enabled = true
  file    = "${params.outputDir}/execution/pipeline.report.html"
  overwrite = true
}

trace {
  enabled   = true
  //file      = "work/pipeline.trace.txt"
  file = "${params.outputDir}/execution/trace.txt"
  overwrite = true
  fields    = 'task_id,process,tag,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem,rss,vmem'
}

conda {
  enabled       = true
  useMamba      = true
  cacheDir      = "/data/$USER/.nxf-conda"

}
singularity {
    enabled = true
    autoPullMode = true
    autoMounts = true
    // cacheDir = "/data/$USER/nxf_singularity_cache"
    envWhitelist = 'https_proxy,http_proxy,ftp_proxy,DISPLAY,SLURM_JOB_ID,SINGULARITY_BINDPATH,MPLCONFIGDIR'
    pullTimeout = '30 min'
}

//Fail on any error in bash script
process.shell = ['/bin/bash', '-euo', 'pipefail']

profiles {
    slurm {
        executor {
            name = 'slurm'
            queue = 'norm'
            pollInterval = '2min'
            queueStatInterval = '5min'
            submitRateLimit = '6/1min'
            retry.maxAttempts = 1
                }
            }
    
    test {
		
        process {
          cpus = 8
          memory = '64 GB'
          time = '6.h'
          // executor = 'local'

          withName: alignMinimap2 {
            cpus = 8
            memory = '64 GB'
            time = '6.h'
          }

          withName: callClair3 {
            cpus = 8
            memory = '64 GB'
          }

          withName: phaseLongphase {
            cpus = 8
            memory = '64 GB'
          }

          withName: haplotagWhatshap {
            cpus = 8
            memory = '64 GB'
          }

          withName: severusTumorOnly {
            cpus = 8
            memory = '64 GB'
          }

          withName: wakhanHapcorrect {
            cpus = 8
            memory = '64 GB'
          }

          withName: wakhanCNA {
            cpus = 8
            memory = '64 GB'
          }

          withName: wakhanHapcorrectTN {
            cpus = 8
            memory = '64 GB'
          }

          withName: wakhanCNATN {
            cpus = 8
            memory = '64 GB'
          }

          withName: deepsomaticTumorOnly {
            cpus = 8
            memory = '64 GB'
            time = '12.h'
          }
        }
  }
}
